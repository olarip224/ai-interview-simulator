# Application
APP_NAME="AI Interview Simulator"
DEBUG=false
API_PREFIX=/api/v1

# Database — asyncpg driver required
DATABASE_URL=postgresql+asyncpg://aiinterviewer:password@localhost:5432/aiinterviewer
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret-before-use
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (JSON list)
CORS_ORIGINS=["http://localhost:3000"]

# Claude AI
ANTHROPIC_API_KEY=sk-ant-your-key-here

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Rate limiting
RATE_LIMIT_ENABLED=true
